      "parameters": {
        "jsCode": "// Reçoit un item par ligne du Google Sheet et reconstruit le tableau objets[]\nconst objets = $input.all().map(item => {\n  const row = item.json;\n  return {\n    id: Number(row.id),\n    nom: row.nom || '',\n    lien: row.lien || '',\n    prix: row.prix !== undefined && row.prix !== '' ? Number(row.prix) : null,\n    reserve: String(row.reserve).trim().toUpperCase() === 'TRUE'\n  };\n});\n\nreturn [{ json: { objets } }];"
      },
